# Compiled object files
*.o
*.ko
*.obj
*.elf

# Precompiled headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app

# Kernel build artifacts
*.mod
*.mod.c
*.cmd
*.order
modules.builtin
Module.symvers

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Dependency files
*.d

# Editor and IDE
*.swp
*.swo
*~
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Build directories
build/
out/

# ELF binaries: ignore all files without extension in examples/
# (compiled executables typically have no extension)
examples/lessons/**/*
!examples/lessons/**/*.*
!examples/lessons/**/Makefile
!examples/lessons/**/README
