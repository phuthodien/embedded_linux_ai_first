{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "gcc build active file",
			"type": "shell",
			"command": "gcc",
			"args": [
				"-g",
				"-O0",
				"-Wall",
				"-Wextra",
				"-std=c99",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}",
				"${file}"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": ["$gcc"]
		},
		{
			"label": "cross compile and deploy to BBB",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"/home/phula/work/bbb/gcc-arm-10.3-2021.07-x86_64-arm-none-linux-gnueabihf/bin/arm-none-linux-gnueabihf-gcc -g -O0 -Wall -Wextra -std=c99 -o ${fileDirname}/${fileBasenameNoExtension} ${file}"
			],
			"problemMatcher": ["$gcc"]
		}
	]
}
